# Copy this file to .env and fill in your local keys.
# .env is ignored by git.

# DeepSeek handles intent parsing and datasheet parameter extraction.
BJT_AI_MODE=cloud
BJT_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash

# Tavily handles web search for datasheets.
BJT_DATASHEET_LOOKUP=1
BJT_DATASHEET_SEARCH_BACKEND=tavily
TAVILY_API_KEY=tvly-your-tavily-key
